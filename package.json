{
  "name": "static-site-learning",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "run-p type:generate type-check build-only",
    "build-only": "vite build",
    "build-only:prod": "vite build --mode prod",
    "build:prod": "run-p type:generate type-check build-only:prod",
    "pretype-check": "pnpm run type:generate",
    "type-check": "vue-tsc --build",
    "type:generate": "node scripts/generate-route-types.js",
    "wordbank:import": "node scripts/import-wordbank-text.js",
    "wordbank:scrape": "node scripts/scrape-wendu-words.js",
    "lint": "eslint . --fix --cache",
    "lint:check": "eslint . --cache",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "check:all": "pnpm run lint:check && pnpm run format:check && pnpm run type-check && pnpm run test:ci",
    "lint-format-check": "run-p lint format type-check",
    "precommit": "pnpm run check:all",
    "test": "pnpm run type:generate && vitest run",
    "test:ci": "pnpm run test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-i18n": "^11.2.2",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "~10.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "typescript": "~5.9.0",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.1.1"
  }
}
